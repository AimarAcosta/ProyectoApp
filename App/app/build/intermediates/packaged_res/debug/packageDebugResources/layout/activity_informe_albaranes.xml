<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Informe de Albaranes"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="24dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvResumenProveedores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Proveedores:"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvTotalImporte"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Importe Total: 0.00 €"
                android:textSize="18sp"
                android:textColor="#3F51B5"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPagados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Albaranes Pagados: 0"
                android:textColor="#4CAF50"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvPendientes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Albaranes Pendientes: 0"
                android:textColor="#F44336"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnCerrarInforme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar Informe"
        android:backgroundTint="#B0BEC5"
        android:textColor="#FFFFFF" />

</LinearLayout>